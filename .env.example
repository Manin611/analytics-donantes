# ====== CONFIGURACIÓN DE API ======
# URL base de la API Spring Boot
# Para desarrollo local:
API_BASE_URL=http://localhost:8080
# Para producción, cambiar a tu URL desplegada:
# API_BASE_URL=https://tu-api-produccion.com

# Timeout para requests (segundos)
API_TIMEOUT=10

# ====== CONFIGURACIÓN DE STREAMLIT (OPCIONAL) ======
# Estos se pueden configurar en .streamlit/config.toml también
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true
